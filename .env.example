# Supabase — copy to .env and fill in to switch the app from sample data to a
# real database. With these unset, the app runs on in-memory sample data.

# Public (browser + server) — used by the app at runtime.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by `npm run seed` to populate the database. Never expose.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
